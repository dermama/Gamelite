<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeFrameLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@id/adapter_item_view"
    android:layout_width="match_parent"
    android:layout_height="@dimen/mw_48dp"
    android:focusable="true"
    android:clickable="true"
    app:shape_radius="@dimen/mw_4dp">
    
    <com.hjq.shape.view.ShapeTextView
        android:id="@id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="@dimen/mw_16dp"
        android:textSize="@dimen/mw_14sp"
        android:textColor="@color/comm_white" />
    
    <ImageView
        android:id="@id/checkbox"
        android:layout_width="@dimen/mw_24dp"
        android:layout_height="@dimen/mw_24dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="@dimen/mw_16dp"
        android:src="@drawable/ic_checked_checkbox"
        android:visibility="gone" />
        
</com.hjq.shape.layout.ShapeFrameLayout>
