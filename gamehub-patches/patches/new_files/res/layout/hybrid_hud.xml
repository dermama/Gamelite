<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_index"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Top Status Overlay Bar -->
    <LinearLayout
        android:id="@+id/hybridStatusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:background="#99000000"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Space B Connection Indicator -->
        <View
            android:id="@+id/connectionIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center_vertical"
            android:background="@android:color/holo_red_dark" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nexus: Offline"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Side Action Floating Buttons Panel -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_margin="16dp"
        android:background="#99000000"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- AI Translate Button -->
        <Button
            android:id="@+id/btnAiTranslate"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="ترجمة AI"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:background="#444444" />

        <!-- Cloud Save Snapshot Button -->
        <Button
            android:id="@+id/btnCloudSave"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="حفظ سحابي"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:background="#444444" />

        <!-- Cloud Restore Snapshot Button -->
        <Button
            android:id="@+id/btnCloudLoad"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="استعادة"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:background="#444444" />

    </LinearLayout>

    <!-- Fullscreen Overlay Canvas for translated Arabic text rendering -->
    <FrameLayout
        android:id="@+id/translationOverlayCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</RelativeLayout>
